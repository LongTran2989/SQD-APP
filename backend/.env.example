# ---------------------------------------------------------------------------
# Backend environment variables — canonical reference.
# Copy to `.env` and fill in. This file is the single source of truth for
# which env vars the backend reads; docs point here instead of re-listing them.
# NOTE: ENFORCE_SINGLE_SESSION is NOT here — it is a DB SystemSetting row,
# not an env var (see auth.middleware.ts).
# ---------------------------------------------------------------------------

# --- Required ---

# PostgreSQL connection string (dev DB: sqd_qa_db). Tests use sqd_qa_test_db
# via .env.test — never point this at the test DB.
DATABASE_URL="postgresql://user:password@localhost:5432/sqd_qa_db"

# Secret used to sign/verify JWTs. Validated at startup (config/env.ts).
JWT_SECRET="super-secret-development-key-12345"

# --- Optional (code-default in parentheses) ---

# HTTP port the API listens on. (index.ts default: 5000)
# PORT=5000

# Node environment; "test" disables rate limiting and single-session checks.
# NODE_ENV=development

# Storage backend for file uploads: "local" or "minio". (config/storage.ts default: local)
# STORAGE_DRIVER=local

# Root directory for local-disk file storage. (default: <cwd>/storage)
# STORAGE_LOCAL_ROOT=

# Allowed CORS origin for the frontend. (index.ts default: http://localhost:3000)
# FRONTEND_ORIGIN=http://localhost:3000

# IANA timezone anchoring cron sweeps and recurrence/date math.
# (autoGenService.ts default: Asia/Ho_Chi_Minh)
# APP_TIMEZONE=Asia/Ho_Chi_Minh

# Escape hatch to disable rate limiting outside tests. Production stays strict.
# DISABLE_RATE_LIMIT=false
