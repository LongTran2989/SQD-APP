# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/sqd_qa_db"
JWT_SECRET="super-secret-development-key-12345"
ENFORCE_SINGLE_SESSION=true

# ─── Google Sheet WP Sync ────────────────────────────────────────────────────
# Public CSV export URL of the MCC maintenance schedule (no OAuth). Format:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/export?format=csv&gid=<SHEET_GID>
GOOGLE_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/REPLACE_WITH_REAL_ID/export?format=csv&gid=0"

# Blueprints are resolved by NAME at sync time (must match an active WpBlueprint).
# TAT <= 2 days → PC-EQ blueprint; TAT > 2 days → CHECK blueprint.
SHEET_CHK_BLUEPRINT_NAME="CHK Blueprint"
SHEET_PC_EQ_BLUEPRINT_NAME="PC-EQ Blueprint"
