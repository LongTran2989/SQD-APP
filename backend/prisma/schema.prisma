generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------
// Organization Hierarchy
// -----------------------------------------------------------------------

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  divisions Division[]
  findings  Finding[]  @relation("FindingDepartment")
  responseActionTargets FindingResponseActionDepartment[] @relation("ResponseActionDepts")
  targetedWorkPackages  WorkPackage[]                     @relation("WorkPackageTargetDepartment")
  deletedAt DateTime?  // Soft delete — Department is referenced by compliance records (Findings, WPs)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Division {
  id            Int           @id @default(autoincrement())
  name          String
  code          String        @unique // e.g. QA, QCH, QCS, SQ — used for templateId generation
  departmentId  Int
  department    Department    @relation(fields: [departmentId], references: [id])
  users         User[]
  templates     Template[]    @relation("TemplateDivision")
  targetedTasks Task[]        @relation("TaskTargetDivision")
  targetedFinds Finding[]     @relation("FindingTargetDivision")
  workPackages  WorkPackage[]
  templateSets  TemplateSet[]
  wpBlueprints  WpBlueprint[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// -----------------------------------------------------------------------
// User & Roles
// -----------------------------------------------------------------------

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique // e.g. Director, Manager, Group Leader, Staff
  users           User[]
  privilegeConfig PrivilegeConfig? // Phase 7 — DB-driven role permission map
}

model User {
  id                   Int       @id @default(autoincrement())
  employeeId           String?   @unique // Staff ID — primary login identifier (e.g. VAE00071)
  name                 String
  email                String?   @unique // Optional — for notifications / password reset only
  phone                String? // Optional contact number
  passwordHash         String
  forcePasswordChange  Boolean   @default(true)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  activeSessionId      String? // UUID tracking the latest active login session

  divisionId Int
  division   Division @relation(fields: [divisionId], references: [id])

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  // Per-user UI state (table column visibility, saved filters). Persisted across devices.
  preferences Json?

  assignedTasks    Task[]    @relation("TaskAssignedTo")
  reportedFindings Finding[] @relation("FindingReportedBy")

  // Templates this user revised or owns
  revisedTemplates Template[]                @relation("TemplateRevisedBy")
  ownedTemplates   Template[]                @relation("TemplateOwnedBy")
  revisionArchives TemplateRevisionArchive[] @relation("ArchiveRevisedBy")

  aircraftAuths UserAircraftAuthorization[]
  jobAuths      UserJobAuthorization[]

  issuedTasks            Task[]                  @relation("TaskIssuer")
  closedFindings         Finding[]               @relation("FindingClosedBy")
  workPackageAssignments WorkPackageAssignment[]
  createdWorkPackages    WorkPackage[]           @relation("WorkPackageCreator")
  feedPosts              FeedPost[]
  timeEntries            TimeEntry[] @relation("UserTimeEntries")

  // Findings expansion reverse relations (virtual — no columns added)
  rcaInvestigations   RcaInvestigation[] @relation("RcaConductedBy")
  ownedCapaActions    CapaAction[]       @relation("CapaOwner")
  verifiedCapaActions CapaAction[]       @relation("CapaVerifiedBy")
  createdCapaActions  CapaAction[]       @relation("CapaCreatedBy")
  createdFindingLinks    FindingLink[]            @relation("FindingLinkCreatedBy")
  createdResponseActions FindingResponseAction[]  @relation("FindingResponseActionCreatedBy")

  // Per-user inbox (Notification Center). Cascade so test teardown that hard-
  // deletes users does not FK-error — notifications are a disposable UI artifact,
  // never the compliance record (AuditLog remains the source of truth).
  notifications Notification[] @relation("UserNotifications")

  // Notification event config rows this user last updated (admin panel).
  notifConfigUpdates NotificationEventConfig[] @relation("NotifConfigUpdatedBy")

  // Files this user uploaded (Attachment owner back-relation).
  uploadedAttachments Attachment[] @relation("AttachmentUploadedBy")

  // Auto-generate ownership (Template Sets / WP Blueprints this user owns).
  ownedTemplateSets TemplateSet[] @relation("TemplateSetOwner")
  ownedBlueprints   WpBlueprint[] @relation("WpBlueprintOwner")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// -----------------------------------------------------------------------
// Aircraft (Authorization + Registration)
// -----------------------------------------------------------------------

model Operator {
  iataCode      String                 @id
  name          String
  registrations AircraftRegistration[]
}

model Authority {
  code          String                 @id
  fullName      String
  registrations AircraftRegistration[]
}

model AircraftType {
  code           String                      @id // e.g. A320, B737, ATR72
  registrations  AircraftRegistration[]
  authorizations UserAircraftAuthorization[]
  createdAt      DateTime                    @default(now())
}

model AircraftRegistration {
  registration     String        @id
  description      String?
  serialNumber     String?
  status           String        @default("Active")
  aircraftTypeCode String?
  aircraftType     AircraftType? @relation(fields: [aircraftTypeCode], references: [code])
  operatorCode     String?
  operator         Operator?     @relation(fields: [operatorCode], references: [iataCode])
  authorityCode    String?
  authority        Authority?    @relation(fields: [authorityCode], references: [code])
  findings         Finding[]
  createdAt        DateTime      @default(now())
}

model UserAircraftAuthorization {
  id               Int          @id @default(autoincrement())
  userId           Int
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  aircraftTypeCode String
  aircraftType     AircraftType @relation(fields: [aircraftTypeCode], references: [code], onDelete: Cascade)

  @@unique([userId, aircraftTypeCode])
}

model AuthorizationType {
  id             Int                    @id @default(autoincrement())
  code           String                 @unique
  description    String?
  category       String?
  authorizations UserJobAuthorization[]
}

model UserJobAuthorization {
  id                  Int               @id @default(autoincrement())
  userId              Int
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorizationTypeId Int
  authorizationType   AuthorizationType @relation(fields: [authorizationTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, authorizationTypeId])
}

// -----------------------------------------------------------------------
// Templates & Tasks
// -----------------------------------------------------------------------

model Template {
  id               Int     @id @default(autoincrement())
  templateId       String  @unique // Auto-generated: [DivisionCode]-[3-digit seq], e.g. QA-001
  title            String
  description      String?
  status           String  @default("Draft") // Draft, Published, Archived
  revision         Int     @default(1)
  requiresApproval Boolean @default(false)
  allowsFindings   Boolean @default(true)
  estimatedHours   Float?
  skillLevel       Int     @default(0) // Required competency level (0-4) seeded onto tasks created from this template
  type             String?
  formSchema       Json // JSON document for active/published field definitions
  draftSchema      Json? // JSON document for unpublished draft changes

  // Division ownership (determines templateId prefix)
  divisionId Int
  division   Division @relation("TemplateDivision", fields: [divisionId], references: [id])

  // Revision tracking
  revisedByUserId Int?
  revisedByUser   User?     @relation("TemplateRevisedBy", fields: [revisedByUserId], references: [id])
  revisedAt       DateTime?

  // Ownership (only owner can edit/publish)
  ownerId Int
  owner   User @relation("TemplateOwnedBy", fields: [ownerId], references: [id])

  tasks            Task[]
  revisionArchives TemplateRevisionArchive[]

  // Auto-generate back-relations (source references; no behaviour here)
  autoGenWorkPackages WorkPackage[]     @relation("WpAutoGenTemplate")
  templateSetItems    TemplateSetItem[]
  blueprintAutoGenWPs WpBlueprint[]     @relation("BlueprintAutoGenTemplate")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
}

model TemplateRevisionArchive {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  revision    Int
  formSchema  Json // Snapshot of the formSchema at this revision
  publishedAt DateTime

  revisedByUserId Int
  revisedByUser   User @relation("ArchiveRevisedBy", fields: [revisedByUserId], references: [id])

  createdAt DateTime @default(now())
}

model Task {
  id         Int      @id @default(autoincrement())
  taskId     String   @unique // e.g. QA-000001
  title      String? // Optional override label; falls back to template.title when null (used by follow-up tasks)
  templateId Int
  template   Template @relation(fields: [templateId], references: [id])

  status String @default("Unassigned") // Assigned, InProgress, Review, Approved, Rejected, etc.

  issuerId Int
  issuer   User @relation("TaskIssuer", fields: [issuerId], references: [id])

  assignedToUserId Int?
  assignedToUser   User? @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id])

  wpId Int?
  wp   WorkPackage? @relation(fields: [wpId], references: [id])

  deadline           DateTime?
  deadlineExtensions Json?
  inactivationLog    Json?
  rejectionReason    String?
  rating             Int?
  estimatedHours     Float?
  skillLevel         Int     @default(0) // Required competency level (0-4); seeded from template, overridable per task
  issuanceNote             String?
  responseActionType       String?
  requiresDirectorApproval Boolean  @default(false)
  // Per-task review gate; seeded from template.requiresApproval at creation, overridable.
  // Independent of requiresDirectorApproval (the Director-only gate always wins).
  requiresApproval         Boolean  @default(true)
  assignmentType           String   @default("INDIVIDUAL")
  schemaSnapshot     Json

  // The division being audited/surveilled
  targetDivisionId Int?
  targetDivision   Division? @relation("TaskTargetDivision", fields: [targetDivisionId], references: [id])

  // If this task is a follow-up action to a finding
  parentFindingId Int?
  parentFinding   Finding? @relation("FindingFollowUpTask", fields: [parentFindingId], references: [id])

  taskData       TaskData?
  sourceFindings Finding[]    @relation("FindingSourceTask")
  timeBooking    TimeBooking?
  timeEntries    TimeEntry[]  @relation("TaskTimeEntries")

  // CAPA reverse relations (virtual — no columns added, no behaviour change)
  capaLinks      CapaTaskLink[]         @relation("CapaLinkedTasks")
  responseAction FindingResponseAction? @relation("TaskResponseAction")

  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([status, deletedAt])
  @@index([targetDivisionId, status, deletedAt])
  @@index([templateId, status, deletedAt])
  @@index([assignedToUserId, status, deletedAt])
  @@index([issuerId, status, deletedAt])
  @@index([completedAt])
}

model TaskData {
  id     Int  @id @default(autoincrement())
  taskId Int  @unique
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  data   Json // The actual answers/inputs matching formSchema

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------
// Findings System
// -----------------------------------------------------------------------

model Finding {
  id          Int     @id @default(autoincrement())
  severity    String? // Observation, Level 1, Level 2
  category    String? // Legacy classification (Safety, Documentation, Tools, etc.) — optional; eventType is the primary classifier
  description String
  status      String  @default("Open") // Open, In Progress, Pending Verification, Closed

  fieldId              String?
  dueDate              DateTime?
  eventType            String
  aircraftRegistrationCode String?
  aircraftRegistration AircraftRegistration? @relation(fields: [aircraftRegistrationCode], references: [registration])
  regulatoryReference  String?
  // @deprecated superseded by structured RCA + CAPA
  errorCode        String?
  // @deprecated superseded by structured RCA + CAPA
  rootCause        String?
  // @deprecated
  correctiveAction String?
  // @deprecated
  recurrence       Boolean?
  // @deprecated
  violatorIds      Json?

  sourceTaskId Int?
  sourceTask   Task? @relation("FindingSourceTask", fields: [sourceTaskId], references: [id])

  reportedByUserId Int
  reportedByUser   User @relation("FindingReportedBy", fields: [reportedByUserId], references: [id])

  closedByUserId Int?
  closedByUser   User? @relation("FindingClosedBy", fields: [closedByUserId], references: [id])

  targetDivisionId Int?
  targetDivision   Division? @relation("FindingTargetDivision", fields: [targetDivisionId], references: [id])

  departmentId Int // Department where the finding occurred — required at raise time
  department   Department @relation("FindingDepartment", fields: [departmentId], references: [id])

  followUpTasks Task[] @relation("FindingFollowUpTask")

  // ── Expansion pack (RCA / CAPA / Taxonomy / Traceability) — all optional ──
  ataChapterId Int?
  ataChapter   AtaChapter?        @relation("FindingAtaChapter", fields: [ataChapterId], references: [id])
  rca          RcaInvestigation?  @relation("FindingRca")
  capaActions  CapaAction[]       @relation("FindingCapa")
  hazardTags   FindingHazardTag[] @relation("FindingHazardTags")
  linksFrom       FindingLink[]            @relation("FindingLinkFrom")
  linksTo         FindingLink[]            @relation("FindingLinkTo")
  responseActions FindingResponseAction[]  @relation("FindingResponseActions")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@index([departmentId, ataChapterId]) // supports the trend recurrence query
}

// -----------------------------------------------------------------------
// Findings Expansion — RCA / CAPA / Taxonomy / Traceability
// -----------------------------------------------------------------------

// Root Cause Analysis — 1:1 with Finding. `method` discriminates which
// structured child set applies (5-Whys ladder vs MEDA contributing factors).
// The determined Cause Code (the conclusion) lives here, not on the Finding.
model RcaInvestigation {
  id        Int     @id @default(autoincrement())
  findingId Int     @unique
  finding   Finding @relation("FindingRca", fields: [findingId], references: [id], onDelete: Cascade)

  method  String // MEDA | FIVE_WHYS | OTHER  (RCA_METHODS)
  summary String? // narrative conclusion / OTHER free-text body
  status  String  @default("Draft") // Draft | Complete (RCA_STATUSES)

  // The determined primary cause — only knowable once the cause is established.
  causeCodeId Int?
  causeCode   CauseCode? @relation("RcaCauseCode", fields: [causeCodeId], references: [id])

  conductedByUserId Int?
  conductedByUser   User? @relation("RcaConductedBy", fields: [conductedByUserId], references: [id])

  whySteps RcaWhyStep[]            @relation("RcaWhySteps")
  factors  RcaContributingFactor[] @relation("RcaFactors")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([method])
  @@index([causeCodeId])
}

// Ordered 5-Whys ladder (method = FIVE_WHYS).
model RcaWhyStep {
  id         Int              @id @default(autoincrement())
  rcaId      Int
  rca        RcaInvestigation @relation("RcaWhySteps", fields: [rcaId], references: [id], onDelete: Cascade)
  orderIndex Int // 0-based ladder position
  question   String
  answer     String?
  createdAt  DateTime         @default(now())

  @@unique([rcaId, orderIndex])
  @@index([rcaId])
}

// MEDA contributing-factor rows (method = MEDA).
model RcaContributingFactor {
  id        Int              @id @default(autoincrement())
  rcaId     Int
  rca       RcaInvestigation @relation("RcaFactors", fields: [rcaId], references: [id], onDelete: Cascade)
  category  String // MEDA category (RCA_MEDA_CATEGORIES)
  detail    String?
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([rcaId])
}

// Corrective / Preventive Action. Sits beside follow-up Tasks; OPTIONALLY
// references existing Tasks for execution and effectiveness verification.
// Never mutates Task fields or the Task status machine.
model CapaAction {
  id        Int     @id @default(autoincrement())
  findingId Int
  finding   Finding @relation("FindingCapa", fields: [findingId], references: [id], onDelete: Cascade)

  type        String // CORRECTIVE | PREVENTIVE (CAPA_TYPES)
  description String
  ownerUserId Int?
  ownerUser   User?     @relation("CapaOwner", fields: [ownerUserId], references: [id])
  deadline    DateTime?
  status      String    @default("Open") // Open | In Progress | Completed | Verified | Waived (CAPA_STATUSES)

  linkedItems CapaTaskLink[] @relation("CapaTaskLinks")

  verifiedByUserId Int?
  verifiedByUser   User?     @relation("CapaVerifiedBy", fields: [verifiedByUserId], references: [id])
  verifiedAt       DateTime?
  waivedReason     String? // required when status = Waived

  createdByUserId Int
  createdByUser   User @relation("CapaCreatedBy", fields: [createdByUserId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([findingId])
  @@index([type, status])
}

// Join table linking a CAPA item to one or more existing Tasks / Work Packages.
// A CAPA may have many linked items; each link carries a role describing how the
// task/WP relates to the action (EXECUTION | EFFECTIVENESS | SUPPORTING).
model CapaTaskLink {
  id        Int          @id @default(autoincrement())
  capaId    Int
  capa      CapaAction   @relation("CapaTaskLinks", fields: [capaId], references: [id], onDelete: Cascade)
  taskId    Int?
  task      Task?        @relation("CapaLinkedTasks", fields: [taskId], references: [id])
  wpId      Int?
  wp        WorkPackage? @relation("CapaLinkedWPs", fields: [wpId], references: [id])
  role      String // EXECUTION | EFFECTIVENESS | SUPPORTING
  createdAt DateTime     @default(now())

  @@index([capaId])
}

// ATA 100 chapter reference lookup (admin-managed).
model AtaChapter {
  id        Int       @id @default(autoincrement())
  code      String    @unique // "05", "32", "100"
  title     String
  isActive  Boolean   @default(true)
  findings  Finding[] @relation("FindingAtaChapter")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Human-factors cause code taxonomy (MEDA-style groups A–J). The conclusion of
// an RCA references one of these.
model CauseCode {
  id        Int                @id @default(autoincrement())
  code      String             @unique // "A01", "H07"
  name      String // cause_name
  groupCode String // "A".."J"
  groupName String
  isActive  Boolean            @default(true)
  rcas      RcaInvestigation[] @relation("RcaCauseCode")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([groupCode])
}

// Hazard tag reference lookup (admin-managed). Many-to-many with Finding.
model HazardTag {
  id          Int                @id @default(autoincrement())
  label       String             @unique // "FOD", "Fatigue", "Tooling Control"
  description String?
  isActive    Boolean            @default(true)
  findings    FindingHazardTag[] @relation("HazardTagJunction")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model FindingHazardTag {
  id          Int       @id @default(autoincrement())
  findingId   Int
  finding     Finding   @relation("FindingHazardTags", fields: [findingId], references: [id], onDelete: Cascade)
  hazardTagId Int
  hazardTag   HazardTag @relation("HazardTagJunction", fields: [hazardTagId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([findingId, hazardTagId])
  @@index([hazardTagId]) // supports trend grouping by hazard tag
}

// Self-referencing cross-reference between two Findings.
model FindingLink {
  id               Int     @id @default(autoincrement())
  fromFindingId    Int
  fromFinding      Finding @relation("FindingLinkFrom", fields: [fromFindingId], references: [id], onDelete: Cascade)
  relatedFindingId Int
  relatedFinding   Finding @relation("FindingLinkTo", fields: [relatedFindingId], references: [id], onDelete: Cascade)

  linkType String // DUPLICATE | RELATED | CAUSED_BY (LINK_TYPES)
  note     String?

  createdByUserId Int
  createdByUser   User     @relation("FindingLinkCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@unique([fromFindingId, relatedFindingId, linkType])
  @@index([relatedFindingId])
}

// Response action raised from a Finding. Created atomically with the generated Task.
// Soft-deleted (never physically removed).
// Target departments stored in FindingResponseActionDepartment join table.
// procedureRef: provision for Change Management phase (QN procedure doc reference).
model FindingResponseAction {
  id        Int     @id @default(autoincrement())
  findingId Int
  finding   Finding @relation("FindingResponseActions", fields: [findingId], references: [id], onDelete: Cascade)

  type   String // CAR | NCR | QN | QR | IR | Dissemination
  taskId Int?   @unique
  task   Task?  @relation("TaskResponseAction", fields: [taskId], references: [id])

  targetDepartments FindingResponseActionDepartment[] @relation("ResponseActionDepts")
  procedureRef      String? // Provision: procedure doc reference for Change Management phase
  note              String? // Optional Manager note

  createdByUserId Int
  createdByUser   User @relation("FindingResponseActionCreatedBy", fields: [createdByUserId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([findingId])
  @@index([type])
}

// Join table: FindingResponseAction ↔ Department (replaces targetDepartmentIds Json).
// Hard-deleted with the parent response action (onDelete: Cascade).
model FindingResponseActionDepartment {
  id               Int                  @id @default(autoincrement())
  responseActionId Int
  responseAction   FindingResponseAction @relation("ResponseActionDepts", fields: [responseActionId], references: [id], onDelete: Cascade)
  departmentId     Int
  department       Department            @relation("ResponseActionDepts", fields: [departmentId], references: [id])
  createdAt        DateTime              @default(now())

  @@unique([responseActionId, departmentId])
  @@index([departmentId])
}

// -----------------------------------------------------------------------
// Audit & Accountability
// -----------------------------------------------------------------------

model AuditLog {
  id         Int    @id @default(autoincrement())
  actionType String // TASK_REASSIGNED, TASK_REJECTED, FINDING_RAISED, etc.
  entityType String // Task, Finding, WorkPackage, etc.
  entityId   String

  performedByUserId Int

  comment String? // User's reasoning or feedback
  details Json? // Technical JSON payload of the change

  timestamp DateTime @default(now())
}

// -----------------------------------------------------------------------
// Notification Center (per-user inbox)
// -----------------------------------------------------------------------
//
// A disposable, per-user UI artifact powering the header inbox bell. NOT a
// compliance record — AuditLog remains the system-of-record (Rule 3), and
// notifications are an additive THIRD write, best-effort. NOT one of the four
// soft-delete-protected models, so it has no `deletedAt` and may be physically
// read/cleared. The User relation is onDelete: Cascade so test teardown that
// hard-deletes users does not FK-error (known handover gotcha).
model Notification {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  type  String // TASK_ASSIGNED | TASK_REVIEWED | TASK_SUBMITTED | ESCALATION_QUEUED | FINDING_CREATED | FEED_ACTIVITY
  title String
  body  String?

  // Deep-link target for the client (e.g. TASK/142, FINDING/8, ESCALATION).
  linkScope String? // TASK | WP | FINDING | ESCALATION
  linkId    Int?

  metadata Json?
  readAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// -----------------------------------------------------------------------
// Notification Event Configuration (admin-configurable per event class)
// -----------------------------------------------------------------------
//
// Drives the Settings → Notifications panel: each row toggles whether a
// notification event class fires (`enabled`) and whether all Managers in the
// recipient's division are CC'd (`ccManagers`). Enforced at the single
// createNotifications chokepoint. Like Notification, this is a config artifact,
// NOT soft-delete protected; AuditLog records every change (Rule 3). Reading is
// fail-open: a missing/unreadable row defaults to enabled (notifications are
// never silently lost).
model NotificationEventConfig {
  eventKey   String  @id // TASK_ASSIGNED | TASK_SUBMITTED | TASK_REVIEWED | FINDING_CREATED | ESCALATION_QUEUED | FEED_ACTIVITY_TASK | FEED_ACTIVITY_WP
  enabled    Boolean @default(true)
  ccManagers Boolean @default(false) // CC all Managers in the recipient's division

  updatedAt   DateTime @updatedAt
  updatedById Int?
  updatedBy   User?    @relation("NotifConfigUpdatedBy", fields: [updatedById], references: [id])
}

// -----------------------------------------------------------------------
// System Configuration
// -----------------------------------------------------------------------

model SystemSetting {
  key         String   @id // e.g. ENFORCE_SINGLE_SESSION
  value       String // e.g. "true", "false", JSON payload
  description String?
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------
// Work Packages
// -----------------------------------------------------------------------

model WorkPackage {
  id   Int    @id @default(autoincrement())
  wpId String @unique // e.g. QA-WP-000001
  name String
  type String // CHECK, AUDIT, etc. Reference to WpType implicitly or by string

  divisionId Int
  division   Division @relation(fields: [divisionId], references: [id])

  timeframeFrom DateTime
  timeframeTo   DateTime

  creatorId Int
  creator   User @relation("WorkPackageCreator", fields: [creatorId], references: [id])

  // ── Auto-generate config (generalized; replaces the old CHECK-only path) ──
  // Any WP type may opt in. Exactly one source (template / set / inline) is set
  // when autoGenerate=true — enforced at the application layer (validateAutoGenConfig).
  autoGenerate      Boolean      @default(false)
  autoGenMode       String? // 'SINGLE_SHOT' | 'REPEAT'
  autoGenInterval   Int? // days between repeats (REPEAT mode only)
  autoGenTemplateId Int? // single-template source (REPEAT, or single-template SINGLE_SHOT)
  autoGenTemplate   Template?    @relation("WpAutoGenTemplate", fields: [autoGenTemplateId], references: [id])
  autoGenSetId      Int? // saved TemplateSet source (SINGLE_SHOT)
  autoGenSet        TemplateSet? @relation(fields: [autoGenSetId], references: [id])
  autoGenInlineSet  Json? // inline InlineTemplateSetItem[] (SINGLE_SHOT)
  autoGenFiredAt    DateTime? // last auto-gen fire — single source of truth for idempotency

  // ── Blueprint origin (null for ad-hoc WPs) ──
  blueprintId Int?
  blueprint   WpBlueprint? @relation(fields: [blueprintId], references: [id])
  isRoutine   Boolean      @default(false)

  // Type-specific fields (CHECK): aircraft/customer/authority context
  acRegistration String?
  customer       String?
  authority      String?

  // Type-specific field (AUDIT): the department being audited
  targetDepartmentId Int?
  targetDepartment   Department? @relation("WorkPackageTargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: SetNull)

  status          String @default("Open") // Open, In Progress, Overdue, Closed, Inactive
  inactivationLog Json?
  closedAt        DateTime? // stamped when status manually transitions to 'Closed' (anchors LAST_DONE recurrence)

  assignments WorkPackageAssignment[]
  tasks       Task[]
  capaLinks   CapaTaskLink[]         @relation("CapaLinkedWPs")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([targetDepartmentId])
  @@index([autoGenerate, status, deletedAt])
}

model WorkPackageAssignment {
  id        Int         @id @default(autoincrement())
  wpId      Int
  wp        WorkPackage @relation(fields: [wpId], references: [id], onDelete: Cascade)
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([wpId, userId])
}

model WpType {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------
// Auto-Generate: Template Sets + WP Blueprints (generalized scheduling)
// -----------------------------------------------------------------------

// A reusable, ordered bundle of templates a SINGLE_SHOT WP can spawn at once.
// Soft-disabled via isActive (never hard-deleted while WPs/blueprints reference it).
model TemplateSet {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  divisionId  Int
  division    Division @relation(fields: [divisionId], references: [id])
  ownerId     Int
  owner       User     @relation("TemplateSetOwner", fields: [ownerId], references: [id])
  isActive    Boolean  @default(true)

  items        TemplateSetItem[]
  workPackages WorkPackage[] // back-relation via WorkPackage.autoGenSetId
  blueprints   WpBlueprint[]     @relation("BlueprintAutoGenSet") // via WpBlueprint.defaultAutoGenSetId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemplateSetItem {
  id         Int         @id @default(autoincrement())
  setId      Int
  set        TemplateSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  templateId Int
  template   Template    @relation(fields: [templateId], references: [id])
  orderIndex Int

  // Per-item overrides (all optional)
  deadlineOffsetDays Int? // days before timeframeTo (subtracted from WP end date)
  estimatedHours     Float?
  skillLevel         Int?
  requiresApproval   Boolean?
  defaultNote        String? // pre-populated issuanceNote

  createdAt DateTime @default(now())

  @@unique([setId, orderIndex])
  @@index([setId])
}

// A reusable WP recipe: pre-fills WP creation values + auto-gen config + an
// (optional) recurrence schedule. "Launch" instantiates a WorkPackage from it.
model WpBlueprint {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        String // WpType code (label only, no behaviour attached)
  divisionId  Int
  division    Division @relation(fields: [divisionId], references: [id])

  // Default WP creation values (all overridable at launch time)
  defaultDuration Int // calendar days (timeframeTo = timeframeFrom + defaultDuration)

  // Auto-generate config — pre-fills the WP's autoGen fields at launch
  defaultAutoGenerate      Boolean      @default(false)
  defaultAutoGenMode       String?
  defaultAutoGenInterval   Int?
  defaultAutoGenTemplateId Int?
  defaultAutoGenTemplate   Template?    @relation("BlueprintAutoGenTemplate", fields: [defaultAutoGenTemplateId], references: [id])
  defaultAutoGenSetId      Int?
  defaultAutoGenSet        TemplateSet? @relation("BlueprintAutoGenSet", fields: [defaultAutoGenSetId], references: [id])
  defaultAutoGenInlineSet  Json?

  // Recurrence scheduling (P7). When recurrenceType is set, the nightly cron
  // auto-launches a routine WP every recurrenceInterval days.
  recurrenceType      String? // 'CALENDAR' | 'LAST_DONE' | null (manual launch only)
  recurrenceInterval  Int? // days between auto-launches
  recurrenceStartDate DateTime? // explicit first-fire date (no implicit "today + interval")
  nextRunAt           DateTime? // cron candidate-query anchor; recomputed after every fire/close

  // Type-specific context defaults (overridable at launch)
  targetDepartmentId Int?
  acRegistration     String?
  customer           String?
  authority          String?

  ownerId  Int
  owner    User    @relation("WpBlueprintOwner", fields: [ownerId], references: [id])
  isActive Boolean @default(true)

  instances WorkPackage[] // back-relation via WorkPackage.blueprintId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventType {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------
// Task Additions (Activity & Time)
// -----------------------------------------------------------------------

// -----------------------------------------------------------------------
// Feed & Escalation System
// -----------------------------------------------------------------------

// Unified feed post across all four scopes. Replaces the former TaskActivity
// model (Task feed = scope 'TASK', scopeId = task.id). scopeId is polymorphic
// (taskId / wpId / divisionId; NULL for the singleton ORG feed) so it carries
// no foreign key — feeds are queried by (scope, scopeId).
model FeedPost {
  id       Int    @id @default(autoincrement())
  type     String // COMMENT | SYSTEM_EVENT | ESCALATION_CARD | INFO_CARD
  scope    String // TASK | WP | DIVISION | ORG
  scopeId  Int? // taskId / wpId / divisionId; NULL for ORG
  authorId Int? // NULL for SYSTEM_EVENT / auto-generated cards
  author   User?  @relation(fields: [authorId], references: [id])
  content  String
  metadata Json?

  // Escalation linkage (populated from Phase 3 onward)
  sourcePostId      Int? // the flagged COMMENT this card references
  sourcePost        FeedPost?       @relation("PostSource", fields: [sourcePostId], references: [id])
  derivedPosts      FeedPost[]      @relation("PostSource")
  sourceExcerpt     String?
  sourceTaskId      Int? // denormalised for deep-linking (no FK — polymorphic origin)
  sourceWpId        Int?
  flagId            Int?
  flag              EscalationFlag? @relation(fields: [flagId], references: [id])
  taggedDivisionIds Json? // Org Feed only — int array of tagged divisions

  createdAt DateTime @default(now())

  @@index([scope, scopeId, createdAt])
  @@index([flagId])
}

// One flag tracks an escalation through its entire lifecycle (no flag chains).
// Immutable record — never soft-deleted.
model EscalationFlag {
  id               Int        @id @default(autoincrement())
  sourcePostId     Int // immutable ref to the original flagged comment
  flaggedByUserId  Int
  targetScope      String // WP | DIVISION | ORG
  status           String     @default("PENDING") // PENDING | ACTIONED | DISMISSED
  reviewedByUserId Int?
  action           String? // ACKNOWLEDGE | DISMISS | RAISE_FINDING | CREATE_TASK | REASSIGN_TASK | DISSEMINATE
  actionedAt       DateTime?
  linkedEntityType String? // Finding | Task
  linkedEntityId   String?
  cards            FeedPost[]
  createdAt        DateTime   @default(now())

  @@index([targetScope, status])
}

model TimeBooking {
  id               Int      @id @default(autoincrement())
  taskId           Int      @unique
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assigneeEntry    Json
  collaborators    Json
  totalHours       Float
  estimatedHours   Float?
  overBudgetReason String?
  overBudgetNote   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TimeEntry {
  id             Int      @id @default(autoincrement())
  taskId         Int
  task           Task     @relation("TaskTimeEntries", fields: [taskId], references: [id], onDelete: Cascade)
  loggedByUserId Int
  loggedBy       User     @relation("UserTimeEntries", fields: [loggedByUserId], references: [id])

  sessionHours        Float
  sessionNotes        String
  collaboratorEntries Json
  overBudgetReason    String?
  overBudgetNote      String?
  loggedAt            DateTime @default(now())

  @@index([taskId, loggedAt])
  @@index([loggedByUserId])
}

// -----------------------------------------------------------------------
// Privileges & Attachments
// -----------------------------------------------------------------------

model PrivilegeConfig {
  id          Int      @id @default(autoincrement())
  roleId      Int      @unique
  role        Role     @relation(fields: [roleId], references: [id])
  permissions Json // Granular permissions map
  updatedAt   DateTime @updatedAt
}

model Attachment {
  id         Int    @id @default(autoincrement())
  fileName   String // original client filename (sanitised before storage)
  fileType   String // MIME type, validated against FILE_UPLOAD_CONFIG
  fileSize   Int // bytes
  bucket     String // logical storage root: sqd-tasks | sqd-findings | sqd-templates
  storageKey String @unique // path within the storage backend (driver-agnostic)

  // Polymorphic owner. entityType ∈ TASK | FINDING | TEMPLATE | WP; entityId is
  // the owning record id (String to mirror AuditLog.entityId). fieldId scopes a
  // file to one form field for TASK form uploads (null for entity-level evidence).
  entityType String
  entityId   String
  fieldId    String?

  uploadedById Int
  uploadedBy   User @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  // Soft delete — evidence files are an aviation compliance record and are never
  // physically dropped from the index (the stored object may be best-effort removed).
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([entityType, entityId, deletedAt])
  @@index([uploadedById])
}
